    <string name="help_quit">Çıkış</string>
    <string name="help_quit_summary">Müzik çalmıyorsa ve Geri düğmesine basarsanız uygulama kapanır. Android, sistem kaynaklarına ihtiyaç duyduğunda uygulamayı kapatabilir.</string>
    <string name="help_stop">Bellekte tut</string>
    <string name="help_stop_summary">Müzik çalmasa ve Ana Sayfa düğmesine bassanız bile uygulama bellekte kalır. Android, sistem kaynaklarına ihtiyaç duyduğunda uygulamayı kapatabilir.</string>
    <string name="help_mediabutton">Medya düğmeleri</string>
