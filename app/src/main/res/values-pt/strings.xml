    <string name="help_seek_menu">Menu de navegação</string>
    <string name="help_seek_menu_summary">Toque no canto superior direito da barra de menu para abrir/fechar o menu de navegação. Toque longo em \"Próxima\"/\"Anterior\" avança/retrocede continuamente.</string>
