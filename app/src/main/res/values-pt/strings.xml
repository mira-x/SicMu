    <string name="help_start_group">Tocar a partir de um grupo</string>
    <string name="help_start_group_summary">Toque longo num grupo para reproduzir a primeira música do grupo.</string>
    <string name="help_next_group">Toque longo em \"Próxima\"</string>
    <string name="help_next_group_summary">Toque longo em \"Próxima\" reproduz a primeira música do próximo grupo (igual para \"Anterior\" para o grupo anterior)</string>
    <string name="help_unfold_group">Abrir/fechar grupo</string>
    <string name="help_unfold_group_summary">Toque num grupo para o abrir ou fechar.</string>
    <string name="help_scroll">Mostrar música atual na lista</string>
    <string name="help_scroll_summary">Pressione o botão à direita de \"Próxima\" para ir à música a tocar. Toque longo fecha todos os grupos exceto a música atual.</string>
    <string name="help_root_folders">Pastas raiz</string>
    <string name="help_root_folders_summary">As pastas raiz configuram-se nas definições avançadas: servem para ocultar a primeira parte do caminho quando as músicas são ordenadas por pasta. Para adicionar várias pastas, separe-as com ponto e vírgula.</string>
    <string name="help_background">Segundo plano</string>
    <string name="help_background_summary">Durante a reprodução, pressionar o botão Início ou Voltar mantém a aplicação em segundo plano.</string>
    <string name="help_quit">Sair</string>
    <string name="help_quit_summary">A aplicação fechará se não houver música a tocar e pressionar o botão Voltar. O Android pode fechar a aplicação quando precisar de recursos do sistema.</string>
    <string name="help_stop">Manter em memória</string>
    <string name="help_stop_summary">A aplicação permanece em memória mesmo se não houver música a tocar e pressionar o botão Início. O Android pode fechar a aplicação quando precisar de recursos do sistema.</string>
    <string name="help_mediabutton">Botões multimédia</string>
    <string name="help_mediabutton_summary">Os botões multimédia (como em auscultadores Bluetooth) podem controlar a aplicação (Próxima, Anterior, Pausar/Tocar).</string>
    <string name="help_mediabutton_autostart">Início automático com botões multimédia</string>
    <string name="help_mediabutton_autostart_summary">Se a aplicação estiver fechada, pressionar os botões multimédia irá iniciá-la. Para desativar, desmarque \"Início automático com botões multimédia\" nas definições.</string>
    <string name="help_details_menu">Informações da música (capa, …)</string>
